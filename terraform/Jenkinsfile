pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "mon-app-cyber:latest"
        CONTAINER_NAME = "openrecon-service"
    }

    stages {
        stage('0. Nettoyage Initial') {
            steps {
                echo "Suppression des anciens conteneurs pour éviter les conflits..."
                // Supprime le conteneur s'il existe, ignore l'erreur s'il n'existe pas
                sh "docker rm -f ${CONTAINER_NAME} || true"
            }
        }

        stage('1. Préparation') {
            steps {
                deleteDir()
                checkout scm
            }
        }

        stage('2. Scan Sécurité (Bandit)') {
            steps {
                sh 'bandit -r . || echo "Vulnérabilités détectées pour le rapport"'
            }
        }

        stage('3. Build Docker') {
            steps {
                echo "Construction de l'image Docker..."
                sh "docker build -t ${DOCKER_IMAGE} ."
            }
        }

        stage('4. Infrastructure (Terraform)') {
            steps {
                dir('terraform') {
                    echo "Déploiement de l'infrastructure avec Terraform..."
                    sh 'terraform init'
                    // On force le refresh pour que Terraform synchronise l'état réel de Docker
                    sh 'terraform apply -auto-approve'
                }
            }
        }

        stage('5. Contrôle Ansible') {
            steps {
                dir('ansible') {
                    echo "Vérification de la configuration avec Ansible..."
                    sh 'ansible-playbook main.yml'
                }
            }
        }
    }

    post {
        success {
            echo "-----------------------------------------------------------"
            echo "VICTOIRE ! L'application est déployée."
            echo "Accès : http://localhost:8081"
            echo "-----------------------------------------------------------"
        }
        failure {
            echo "Le pipeline a échoué. Vérifiez si un conteneur bloque encore manuellement."
        }
    }
}
